#!/usr/bin/env bash
# This script configures /etc/hosts to redirect localhost and facebook.com
# It uses a method that works even if /etc/hosts is a bind-mount.

# Read the file, replace the IP, and overwrite the content
new_hosts=$(sed 's/127.0.0.1/127.0.0.2/g' /etc/hosts)
echo "$new_hosts" > /etc/hosts

# Append the facebook redirection
echo "8.8.8.8 facebook.com" >> /etc/hosts
